generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanilhaInstalacao {
  id                    String   @id @default(cuid())
  idInterno             String?  @unique
  instalacao            String?
  diaPrev               String?
  manualInstalacao      Boolean  @default(false)
  obsInstalacao         String?
  vencimentoParecer     String?
  vencimentoContrato    String?
  automaticoPrevInstala String?
  dataVenda             String?
  statusProtocolo       String?
  statusCompra          String?
  inversor              String?
  numMod                String?
  modulo                String?
  cidadeSheet           String?
  bairro                String?
  rua                   String?
  numRua                String?
  telhado               String?
  telefoneSheet         String?
  vendedorSheet         String?
  observacao            String?
  anexoFotos            String[]
  anexoArquivos         String[]
  dataSolicitacao       DateTime @default(now())
  solicitacao           String?
  status                String?  @default("Pendente")
  vendedor              String?
  telefoneCliente       String?
  cidade                String?
  dataPrevista          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  atividadeExtra        Boolean  @default(false)
  prioridade            Boolean  @default(false)
  telefoneVendedor      String?
  notificadoWhatsapp     Boolean  @default(false)

  @@index([idInterno])
}

model Tarifas {
  id             String   @id @default(cuid())
  distribuidora  String
  subGrupo       String
  modalidade     String
  postoTarifario String
  valorTUSD      Float
  valorTE        Float
  dataInicio     DateTime
  resolution     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([distribuidora, subGrupo, modalidade, postoTarifario])
}

model StatusOption {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id            String   @id @default("default")
  limiteVerde   Int      @default(40)
  limiteAmarelo Int      @default(20)
  limiteParecer Int      @default(30)
  updatedAt     DateTime @updatedAt
}

model Carregador {
  id            String                   @id @default(cuid())
  brand         String
  model         String
  power         Float
  voltage       Int
  phases        Int
  current       Float
  connectorType String?
  protectionReq String?
  groundingReq  String?
  datasheetUrl  String?
  imageUrl      String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  projects      ProjetoDimensionamento[]
}

model ProjetoDimensionamento {
  id                   String     @id @default(cuid())
  projectName          String
  clientName           String?
  utility              String     @default("CEMIG")
  entranceCategory     String?
  distance             Float
  installationMethod   String
  chargerId            String
  calculatedCurrent    Float
  calculatedCableGauge Float
  calculatedBreaker    Float
  calculatedDR         String?
  calculatedConduit    String?
  voltageDrop          Float
  groundingAnalysis    String?
  isServiceEntranceOk  Boolean    @default(true)
  analysisNotes        String?
  
  // Novos campos para Transformador e Proteção Avançada
  hasTransformer             Boolean @default(false)
  transformerPrimaryVoltage  Float?  @default(220)
  transformerSecondaryVoltage Float?  @default(380)
  transformerDistance        Float?  @default(10) // QGBT até Transfo
  chargerDistance            Float?  @default(10) // Transfo até Carregador
  groundingType              String? @default("TT")
  calculatedPrimaryCable     Float?
  calculatedPrimaryBreaker   Float?
  calculatedDPS              String?
  calculatedIDR              String?
  
  // Novos campos para CEMIG e Gestão
  existingLoadKW             Float?  @default(0)
  simultaneityFactor         Float?  @default(0.8)
  isCollective               Boolean @default(false)
  location                   String? @default("urbano")

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  charger              Carregador @relation(fields: [chargerId], references: [id])
}

model EngeProjeto {
  id            String              @id @default(cuid())
  nome          String
  cliente       String?
  tipo          String
  status        String              @default("Rascunho")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  analiseFatura AnaliseFatura?
  analiseMassa  AnaliseMassaDados[]
  estudoBESS    EstudoBESS?
  estudoSolar   EstudoSolar?
}

model AnaliseFatura {
  id                    String      @id @default(cuid())
  projetoId             String      @unique
  nomeCliente           String?
  endereco              String?
  concessionaria        String?
  numeroInstalacao      String?
  cnpjCpfTitular        String?
  grupoTarifario        String?
  subgrupo              String?
  modalidadeTarifaria   String?
  classeConsumo         String?
  consumoMeses          Json?
  consumoMedioMensalKWh Float?
  consumoTotalAnualKWh  Float?
  demandaContratadaKW   Float?
  demandaMedidaHPKW     Float?
  demandaMedidaHFPKW    Float?
  temGeracao            Boolean     @default(false)
  geracaoTipos          String?
  geracaoInjetadaKWh    Float?
  tusd                  Float?
  te                    Float?
  tarifaHP              Float?
  tarifaHFP             Float?
  tarifaDemandaHP       Float?
  tarifaDemandaHFP      Float?
  valorUltimaFatura     Float?
  bandeiraTarifaria     String?
  rawPdfUrl             String?
  extraidoPorIA         Boolean     @default(false)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  padraoConexao         String?
  descontoIrrigante     Float?
  energiaAtivaHRKWh     Float?
  mesReferencia         String?
  vencimento            String?
  projeto               EngeProjeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
}

model AnaliseMassaDados {
  id                  String      @id @default(cuid())
  projetoId           String
  rawXlsUrls          String[]
  nomeArquivos        String[]
  postoHP_inicio      String?     @default("18:00")
  postoHP_fim         String?     @default("21:00")
  postoHFP_inicio     String?     @default("21:00")
  postoHFP_fim        String?     @default("18:00")
  postoHR_inicio      String?
  postoHR_fim         String?
  diasUteisSemana     Int[]       @default([1, 2, 3, 4, 5])
  periodoInicio       DateTime?
  periodoFim          DateTime?
  totalRegistros      Int?
  maxDemandaHP        Float?
  maxDemandaHFP       Float?
  maxDemandaHR        Float?
  maxDemandaTotal     Float?
  consumoHP_kWh       Float?
  consumoHFP_kWh      Float?
  consumoHR_kWh       Float?
  curvaMediaDiaria    Json?
  curvaHP             Json?
  curvaHFP            Json?
  diaCriticoData      DateTime?
  diaCriticoDemandaKW Float?
  diaCriticoCurva     Json?
  mediaDiaCritico     Float?
  maxDemandaTotalData DateTime?
  minDemandaTotal     Float?
  minDemandaTotalData DateTime?
  processado          Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  projeto             EngeProjeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
}

model InversorSolar {
  id                String   @id @default(cuid())
  fabricante        String
  modelo            String
  potenciaNominalKW Float
  tipoConexao       String
  tensaoEntradaMinV Float?
  tensaoEntradaMaxV Float?
  correnteMaxCC     Float?
  numeroStringsMPPT Int?
  potenciaMPPTKW    Float?
  tensaoSaidaVAC    Float?
  fatorPotencia     Float?
  eficiencia        Float?
  comunicacao       String?
  ipBD              String?
  datasheetUrl      String?
  ieee1547Compliant Boolean? @default(false)
  responseTimeMs    Float?
  thdMax            Float?
  powerFactorControl Boolean? @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  fase              Int?     @default(1)
}

model ModuloFotovoltaico {
  id             String   @id @default(cuid())
  fabricante     String
  modelo         String
  potenciaPicoWp Float
  Vmp            Float?
  Imp            Float?
  Voc            Float?
  Isc            Float?
  eficiencia     Float?
  dimensoes      String?
  pesoKg         Float?
  coefTempVoc    Float?
  coefTempIsc    Float?
  garantiaAnos   Int?
  datasheetUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BateriaSistema {
  id                   String   @id @default(cuid())
  fabricante           String
  modelo               String
  tecnologia           String
  capacidadeNomKWh     Float
  tensaoNominalV       Float?
  profundidadeDescarga Float?
  ciclosVida           Int?
  correnteMaxCarga     Float?
  correnteMaxDescarga  Float?
  tempOperacaoMin      Float?
  tempOperacaoMax      Float?
  roundTripEfficiency  Float?
  standbyLossesKW      Float?
  thermalBufferLower   Float?   @default(0.1)
  thermalBufferUpper   Float?   @default(0.9)
  datasheetUrl         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model EstruturaFotovoltaica {
  id                String   @id @default(cuid())
  fabricante        String
  modelo            String
  tipoTelhado       String
  materialEstrutura String?
  cargaMaxVentoKNm2 Float?
  modulosMaxFileira Int?
  anguloMin         Float?
  anguloMax         Float?
  datasheetUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EstudoBESS {
  id                 String      @id @default(cuid())
  projetoId          String      @unique
  demandaAlvoKW      Float?
  estrategia         String?
  bateriaId          String?
  inversorId         String?
  quantidadeBaterias Int         @default(1)
  picoReduzidoKW     Float?
  economiaMensalLeve Float?
  economiaMensalBESS Float?
  paybackSimples     Float?
  vpl                Float?
  tir                Float?
  configSimulacao    Json?
  resultadosGrafico  Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  projeto            EngeProjeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
}

model EstudoSolar {
  id                    String      @id @default(cuid())
  projetoId             String      @unique
  lat                   Float?
  long                  Float?
  hspManual             Float?
  hspPvgis              Float?
  tilt                  Float       @default(0)
  azimuth               Float       @default(0)
  pr                    Float       @default(0.75)
  perdaSistema          Float       @default(0.14)
  geracaoAlvoKWh        Float?
  potenciaNecessariaKWp Float?
  moduloId              String?
  inversorId            String?
  quantidadeModulos     Int         @default(0)
  quantidadeInversores  Int         @default(1)
  numStrings            Int         @default(1)
  modulosPorString      Int         @default(1)
  areaOcupadaM2         Float?
  pesoTotalKg           Float?
  investimentoEstimado  Float?
  paybackAnos           Float?
  vpl                   Float?
  tir                   Float?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  inversoresSugeridos   Json?
  overEnclosureAlvo     Float?      @default(1.40)
  projeto               EngeProjeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
}
