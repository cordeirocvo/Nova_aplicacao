generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   // "ADMIN" or "TV"
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanilhaInstalacao {
  id                      String   @id @default(cuid())
  
  // Mirrored fields from Google Sheets
  idInterno               String?  @unique // Column 'x'
  instalacao              String?  // Column 'Instalação - Pedro Cliente'
  diaPrev                 String?
  manualInstalacao        Boolean  @default(false)
  obsInstalacao           String?
  vencimentoParecer       String?
  vencimentoContrato      String?
  automaticoPrevInstala   String?
  dataVenda               String?
  statusProtocolo         String?
  statusCompra            String?
  inversor                String?
  numMod                  String?
  modulo                  String?
  cidadeSheet             String?
  bairro                  String?
  rua                     String?
  numRua                  String?
  telhado                 String?
  telefoneSheet           String?
  vendedorSheet           String?

  // Additional fields requested by the user
  observacao              String?
  anexoFotos              String[] // Array of URLs (Supabase storage)
  anexoArquivos           String[] // Array of URLs (Supabase storage)
  dataSolicitacao         DateTime @default(now())
  solicitacao             String?
  status                  String?  @default("Pendente")
  vendedor                String?
  telefoneCliente         String?
  cidade                  String?
  dataPrevista            String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  prioridade              Boolean  @default(false)
  atividadeExtra          Boolean  @default(false)

  @@index([idInterno])
}

model Tarifas {
  id                String   @id @default(cuid())
  distribuidora     String   // SigAgente (e.g., CEMIG-D)
  subGrupo          String   // DscSubGrupo (e.g., A4)
  modalidade        String   // DscModalidadeTarifaria (Azul/Verde)
  postoTarifario    String   // NomPostoTarifario (Ponta/Fora Ponta)
  valorTUSD         Float
  valorTE           Float
  dataInicio        DateTime
  resolution        String?  // DscREH
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([distribuidora, subGrupo, modalidade, postoTarifario])
}

model StatusOption {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?  // hex code or tailwind class
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id              String   @id @default("default")
  limiteVerde     Int      @default(40)
  limiteAmarelo   Int      @default(20)
  limiteParecer   Int      @default(30)
  updatedAt       DateTime @updatedAt
}

model Carregador {
  id                String   @id @default(cuid())
  brand             String
  model             String
  power             Float    // kW
  voltage           Int      // 220, 380, etc.
  phases            Int      // 1 or 3
  current           Float    // Max current in Amperes
  connectorType     String?  // T2, T1, GB/T
  protectionReq     String?  // DR type etc
  groundingReq      String?
  datasheetUrl      String?
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  projects          ProjetoDimensionamento[]
}

model ProjetoDimensionamento {
  id                    String   @id @default(cuid())
  projectName           String
  clientName            String?
  utility               String   @default("CEMIG")
  entranceCategory      String?  // "C1", "B2", etc.
  distance              Float    // meters
  installationMethod    String   // NBR 5410 methods (e.g., B1, C)
  
  chargerId             String
  charger               Carregador @relation(fields: [chargerId], references: [id])
  
  calculatedCurrent     Float
  calculatedCableGauge  Float    // mm2
  calculatedBreaker     Float    // Amperes
  calculatedDR          String?  // "30mA Tipo A", etc.
  calculatedConduit     String?  // mm or inches
  voltageDrop           Float    // Percentage
  
  groundingAnalysis     String?
  isServiceEntranceOk   Boolean  @default(true)
  analysisNotes         String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── MÓDULO ENGENHARIA & CÁLCULOS ─────────────────────────────────────────

model ProjetoEngenharia {
  id                String   @id @default(cuid())
  nome              String
  cliente           String?
  tipo              String   // BESS | SOLAR | HYBRID | CARREGADOR
  status            String   @default("Rascunho")

  analiseFatura     AnaliseFatura?
  analiseMassa      AnaliseMassaDados[]
  estudoBESS        EstudoBESS?
  estudoSolar       EstudoSolar?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AnaliseFatura {
  id                    String   @id @default(cuid())
  projetoId             String   @unique
  projeto               ProjetoEngenharia @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  // Identificação
  concessionaria        String?   // CEMIG, COPEL, CELESC...
  numeroInstalacao      String?
  cnpjCpfTitular        String?

  // Grupo Tarifário (ANEEL REN 1000/2021)
  grupoTarifario        String?   // A ou B
  subgrupo              String?   // A1,A2,A3,A3a,A4,AS,B1,B2,B3,B4
  modalidadeTarifaria   String?   // CONVENCIONAL | AZUL | VERDE | BRANCA | HORARIA_VERDE | HORARIA_AZUL
  classeConsumo         String?   // Residencial | Comercial | Industrial | Rural | Iluminação Pública...

  // Consumo (12 meses)
  consumoMeses          Json?     // [{mes: '2024-01', kwh: 1234, injetado: 0, bandeira: 'verde'}, ...]
  consumoMedioMensalKWh Float?
  consumoTotalAnualKWh  Float?

  // Demanda (para Grupo A)
  demandaContratadaKW   Float?
  demandaMedidaHPKW     Float?
  demandaMedidaHFPKW    Float?

  // Geração Distribuída detectada
  temGeracao            Boolean  @default(false)
  geracaoTipos          String?  // ex: "Solar fotovoltaico"
  geracaoInjetadaKWh    Float?   // kWh injetados no período

  // Tarifas extraídas
  tusd                  Float?   // R$/kWh
  te                    Float?   // R$/kWh
  tarifaHP              Float?
  tarifaHFP             Float?
  tarifaDemandaHP       Float?   // R$/kW
  tarifaDemandaHFP      Float?
  valorUltimaFatura     Float?
  bandeiraTarifaria     String?  // Verde | Amarela | Vermelha 1 | Vermelha 2

  // Arquivo original
  rawPdfUrl             String?
  extraidoPorIA         Boolean  @default(false)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AnaliseMassaDados {
  id                    String   @id @default(cuid())
  projetoId             String
  projeto               ProjetoEngenharia @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  // Arquivos originais
  rawXlsUrls            String[] // URLs no Supabase Storage
  nomeArquivos          String[] // nomes originais

  // Configuração dos postos tarifários
  postoHP_inicio        String?  @default("18:00") // HH:MM
  postoHP_fim           String?  @default("21:00")
  postoHFP_inicio       String?  @default("21:00")
  postoHFP_fim          String?  @default("18:00")
  postoHR_inicio        String?  // Horário Reservado (opcional — tarifas verdes)
  postoHR_fim           String?
  diasUteisSemana       Int[]    @default([1,2,3,4,5]) // 1=Seg..7=Dom

  // Resultados processados (pico de demanda em cada posto — período completo)
  periodoInicio         DateTime?
  periodoFim            DateTime?
  totalRegistros        Int?

  // Demanda máxima por posto (kW)
  maxDemandaHP          Float?
  maxDemandaHFP         Float?
  maxDemandaHR          Float?
  maxDemandaTotal       Float?

  // Consumo total por posto (kWh)
  consumoHP_kWh         Float?
  consumoHFP_kWh        Float?
  consumoHR_kWh         Float?

  // Curva de carga média diária (96 pontos de 15min ou 24 pontos horários) — JSON
  curvaMediaDiaria      Json?    // [{hora: 0, kw: 12.3}, ...]
  curvaHP               Json?    // curva nos dias de semana apenas no HP
  curvaHFP              Json?

  // Dia crítico identificado
  diaCriticoData        DateTime?
  diaCriticoDemandaKW   Float?
  diaCriticoCurva       Json?    // curva do dia de maior demanda

  processado            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── EQUIPAMENTOS (FASE 2) ────────────────────────────────────────────────

model InversorSolar {
  id                String   @id @default(cuid())
  fabricante        String
  modelo            String
  potenciaNominalKW Float
  tipoConexao       String   // ON_GRID | OFF_GRID | HYBRID
  
  // Especificações CC
  tensaoEntradaMinV Float?
  tensaoEntradaMaxV Float?
  correnteMaxCC     Float?
  numeroStringsMPPT Int?
  potenciaMPPTKW    Float?
  
  // Especificações CA
  tensaoSaidaVAC    Float?
  fatorPotencia     Float?
  eficiencia        Float?
  
  // Outros
  comunicacao       String?  // WiFi / RS485 / Ethernet
  ipBD              String?  // IP65, IP66
  datasheetUrl      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ModuloFotovoltaico {
  id                String   @id @default(cuid())
  fabricante        String
  modelo            String
  potenciaPicoWp    Float
  Vmp               Float?
  Imp               Float?
  Voc               Float?
  Isc               Float?
  eficiencia        Float?
  dimensoes         String?  // ex: 2279x1134x35 mm
  pesoKg            Float?
  coefTempVoc       Float?
  coefTempIsc       Float?
  garantiaAnos      Int?
  datasheetUrl      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model BateriaSistema {
  id                String   @id @default(cuid())
  fabricante        String
  modelo            String
  tecnologia        String   // LFP | NMC | AGM | GEL | VRLA
  capacidadeNomKWh  Float
  tensaoNominalV    Float?
  profundidadeDescarga Float? // DOD % (ex: 0.8 para 80%)
  ciclosVida        Int?
  correnteMaxCarga  Float?
  correnteMaxDescarga Float?
  tempOperacaoMin   Float?
  tempOperacaoMax   Float?
  datasheetUrl      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EstruturaFotovoltaica {
  id                String   @id @default(cuid())
  fabricante        String
  modelo            String
  tipoTelhado       String   // CERAMICO | METALICO | FIBROCIMENTO | LAJE | SOLO | CARPORT
  materialEstrutura String?  // Aluminio | Aco
  cargaMaxVentoKNm2 Float?
  modulosMaxFileira Int?
  anguloMin         Float?
  anguloMax         Float?
  datasheetUrl      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
model EstudoBESS {
  id                    String   @id @default(cuid())
  projetoId             String   @unique
  projeto               ProjetoEngenharia @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  
  // Configurações da simulação
  demandaAlvoKW         Float?
  estrategia            String?   // PEAK_SHAVING | TIME_SHIFTING | HYBRID | BACKUP
  
  // Equipamentos selecionados (IDs da biblioteca)
  bateriaId             String?
  inversorId            String?
  quantidadeBaterias    Int      @default(1)
  
  // Resultados da simulação
  picoReduzidoKW        Float?
  economiaMensalLeve    Float?   
  economiaMensalBESS    Float?   
  paybackSimples        Float?
  vpl                   Float?
  tir                   Float?
  
  configSimulacao       Json?    // Detalhes extras (preço kWh, inflação, etc)
  resultadosGrafico     Json?    // Dados da curva simulada
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
model EstudoSolar {
  id                    String   @id @default(cuid())
  projetoId             String   @unique
  projeto               ProjetoEngenharia @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  
  // Localização e Irradiação
  lat                   Float?
  long                  Float?
  hspManual             Float?
  hspPvgis              Float?
  pr                    Float    @default(0.75) // Performance Ratio (ajustável)
  perdaSistema          Float    @default(0.14) // Outras perdas (sujeira, cabos, etc)
  
  // Dimensionamento Energético
  geracaoAlvoKWh        Float?
  potenciaNecessariaKWp Float?
  
  // Equipamentos Selecionados (IDs da biblioteca)
  moduloId              String?
  inversorId            String?
  quantidadeModulos     Int      @default(0)
  quantidadeInversores  Int      @default(1)
  
  // Configuração Elétrica
  numStrings            Int      @default(1)
  modulosPorString      Int      @default(1)
  areaOcupadaM2         Float?
  pesoTotalKg           Float?
  
  // Resultados Financeiros
  investimentoEstimado  Float?
  paybackAnos           Float?
  vpl                   Float?
  tir                   Float?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
